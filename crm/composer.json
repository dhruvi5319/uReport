{
    "name": "city-of-bloomington/ureport",
    "description": "uReport",
    "require": {
        "php": ">=8.5",
        "facile-it/php-openid-client":     "@stable",
        "graylog2/gelf-php":               "@stable",
        "guzzlehttp/guzzle":               "@stable",
        "solarium/solarium":               "@stable",
        "symfony/event-dispatcher":        "@stable",
        "phpmailer/phpmailer":             "@stable",
        "laminas/laminas-permissions-acl": "@stable",
        "robmorgan/phinx":                 "^0.16"
    },
    "require-dev": {
        "phpunit/phpunit": "@stable",
        "phpstan/phpstan": "@stable"
    },
    "autoload": {
        "psr-4": {
            "Application\\":   "src/Application",
            "Domain\\":        "src/Domain",
            "Repositories\\":  "src/Repositories",
            "Infrastructure\\": "src/Infrastructure",
            "Test\\":          "src/Test"
        }
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
